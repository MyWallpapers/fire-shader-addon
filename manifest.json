{
  "name": "Fire Shader Effect",
  "version": "2.0.0",
  "sdkVersion": "2.17.1",
  "description": "Realistic animated fire effect with customizable colors and fluid dynamics. WebGL2 shader with Fractal Brownian Motion.",
  "author": "MyWallpaper Community",
  "type": "widget",
  "categories": ["effects", "animations", "backgrounds"],
  "license": "MIT",
  "repository": "https://github.com/rayandu924/fire-shader-addon",

  "capabilities": {
    "hotReload": true,
    "systemEvents": ["viewport:resize"]
  },

  "defaultLayout": {
    "xPercent": 0,
    "yPercent": 0,
    "widthPercent": 100,
    "heightPercent": 100,
    "rotation": 0
  },

  "ui": {
    "pointerEvents": "none"
  },

  "settings": {
    "colorsSection": {
      "type": "section",
      "label": "🎨 Colors"
    },
    "primaryColor": {
      "type": "color",
      "label": "Primary Color",
      "default": "#FF6B35"
    },
    "secondaryColor": {
      "type": "color",
      "label": "Secondary Color",
      "default": "#FF0000"
    },

    "motionSection": {
      "type": "section",
      "label": "🔥 Motion"
    },
    "speed": {
      "type": "range",
      "label": "Speed",
      "description": "Flame animation speed",
      "min": 0.0,
      "max": 1.0,
      "step": 0.05,
      "default": 0.2
    },

    "appearanceSection": {
      "type": "section",
      "label": "🌫️ Appearance"
    },
    "intensity": {
      "type": "range",
      "label": "Intensity",
      "description": "Overall fire brightness",
      "min": 0.0,
      "max": 2.0,
      "step": 0.1,
      "default": 0.9
    },
    "scale": {
      "type": "range",
      "label": "Scale",
      "description": "Size of fire details (smaller = more details)",
      "min": 1.0,
      "max": 15.0,
      "step": 0.5,
      "default": 7.0
    },
    "turbulence": {
      "type": "range",
      "label": "Turbulence",
      "description": "Chaos and movement level",
      "min": 0.0,
      "max": 2.0,
      "step": 0.1,
      "default": 0.9
    },
    "height": {
      "type": "range",
      "label": "Height",
      "description": "Vertical size of flames",
      "min": 0.3,
      "max": 3.0,
      "step": 0.1,
      "default": 1.0
    },
    "opacity": {
      "type": "range",
      "label": "Opacity",
      "description": "Overall transparency",
      "min": 0.0,
      "max": 1.0,
      "step": 0.05,
      "default": 1.0
    }
  }
}
